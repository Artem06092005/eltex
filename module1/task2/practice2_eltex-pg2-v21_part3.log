1-3.Зарегистрируйтесь на сайте github.com, если еще не сделали этого ранее
Установите параметры git в соответствии с вашими учетными данными
----------------------------------------------------------------------------

root@eltex-practice2-pg2-v21:~# git config --global user.name Artem06092005"
root@eltex-practice2-pg2-v21:~# git config --global user.email "chirkin.aleksandrowich@yandex.ru
root@eltex-practice2-pg2-v21:~# git config --global init.defaultBranch main
root@eltex-practice2-pg2-v21:~# apt update

