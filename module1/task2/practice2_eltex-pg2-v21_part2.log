4. В файле /etc/passwd найдите всех пользователей в системе, у которых установлен shell /usr/sbin/nologin
 и выведите их в виде списка: «UID, username, список его групп», отсортированный в обратном порядке по UID,
 cписок групп используйте из файла /etc/group
---------------------------------------------------------------------------------------------------------


root@eltex-practice2-pg2-v21:~# cat ~/opt/task4.sh
#/bin/bash


while IFS=: read -r user _ uid gid _ _ shell; do
        if [[ "$shell" == "/usr/sbin/nologin" ]]; then
                groups=$(id -Gn $user | tr ' ' ',')
                echo "$uid , $user , $groups"
        fi
done < /etc/passwd | sort -rn
root@eltex-practice2-pg2-v21:~#


root@eltex-practice2-pg2-v21:~/opt# chmod +x task4.sh
root@eltex-practice2-pg2-v21:~/opt# ./task4.sh
